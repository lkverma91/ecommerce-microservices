# ==============================================================
# Environment Variables for ecommerce-microservices
# ==============================================================
# Copy to .env and fill values:   cp .env.example .env
# NEVER commit .env with real secrets.
# ==============================================================

# --- Spring Profile ---
# Defaults to "docker" for local dev (see docker-compose.yml).
# Overridden to "prod" in docker-compose.prod.yml.
# SPRING_PROFILES_ACTIVE=docker

# --- Database (single PostgreSQL instance, multiple databases) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# POSTGRES_DB=postgres  (default admin DB)
# Databases created automatically by init-db/01-create-databases.sh:
#   user_db, product_db, order_db, inventory_db, payment_db

# --- Kafka ---
# KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# --- Zipkin ---
# ZIPKIN_URL=http://zipkin:9411/api/v2/spans
# ZIPKIN_STORAGE_TYPE=mem

# --- Redis ---
# REDIS_HOST=redis
# REDIS_PORT=6379

# --- API Gateway / Security ---
# CRITICAL: Generate a strong secret for production!
#   openssl rand -base64 32
JWT_SECRET=my-local-dev-secret-change-in-production
# JWT_EXPIRATION_MS=86400000

# --- OAuth2 (auth-service). Register apps at provider dev consoles and set below. ---
# Redirect URI to register with each provider: {OAUTH2_REDIRECT_URI_BASE}/login/oauth2/code/{registrationId}
# Example: http://localhost:8080/api/auth/login/oauth2/code/google
OAUTH2_REDIRECT_URI_BASE=http://localhost:8080/api/auth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=

# --- Auth-service frontend redirect (after OAuth login) ---
FRONTEND_BASE_URL=http://localhost:5173

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_REPLENISH=10
RATE_LIMIT_BURST=20

# --- Frontend ---
# VITE_API_BASE_URL=/api
